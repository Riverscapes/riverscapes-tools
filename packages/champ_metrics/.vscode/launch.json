{
  // Use IntelliSense to learn about possible attributes.
  // Hover to view descriptions of existing attributes.
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "inputs": [
    {
      "type": "promptString",
      "id": "visitID",
      "description": "Which Visit ID?",
      "default": "213"
    }
  ],
  "configurations": [
    {
      "name": "Python: Current File",
      "type": "debugpy",
      "request": "launch",
      "program": "${file}",
      "console": "integratedTerminal"
    },
    {
      "name": "CHaMP Metrics",
      "type": "debugpy",
      "module": "champ_metrics.run_champ_metrics",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/../../lib/commons"
      }, 
      "args": [
        "/Users/philipbailey/GISData/riverscapes/topo/visit_213/project.rs.xml",
        "/Users/philipbailey/GISData/riverscapes/topo/visit_213"
      ],
      "request": "launch",
      "console": "integratedTerminal"
    },
    {
      "name": "CHaMP Metrics With Project Update",
      "type": "debugpy",
      "module": "champ_metrics.champ_metrics",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/../../lib/commons"
      }, 
      "args": [
        // "/Users/philipbailey/GISData/riverscapes/topo/visit_2059/project.rs.xml",
        // "/Users/philipbailey/GISData/riverscapes/topo/visit_213/project.rs.xml"
        "/Users/philipbailey/GISData/riverscapes/topo/lemhi/project.rs.xml"
      ],
      "request": "launch",
      "console": "integratedTerminal"
    },
    {
      "name": "BATCH CHaMP Metrics",
      "type": "debugpy",
      "module": "champ_metrics.run_champ_metrics_batch",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/../../lib/commons"
      }, 
      "args": [
        "{env:CSV_FOLDER}",
        "{env:DATA_ROOT}/champ/topo_projects",
        "{env:DATA_ROOT}/champ/metrics"
      ],
      "request": "launch",
      "console": "integratedTerminal"
    },
    {
      "name": "Stream Temp",
      "type": "debugpy",
      "module": "champ_metrics.stream_temp",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/../../lib/commons"
      }, 
      "args": [
        "/Users/philipbailey/GISData/champ/stream_temp/whatever",
        "/Users/philipbailey/GISData/champ/stream_temp/champ_stream_temp.gpkg",
        "/Users/philipbailey/GISData/champ/stream_temp/champ_site_locations.json"
      ],
      "request": "launch",
      "console": "integratedTerminal"
    },
    {
      "name": "Photo Scraper",
      "type": "debugpy",
      "module": "champ_metrics.scripts.photo_scraper",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/../../lib/commons"
      }, 
      "args": [
        "/Users/philipbailey/GISData/champ/photos/processing_status.json",
        "/Users/philipbailey/GISData/champ/photos/visit_data.json",
        "/Users/philipbailey/GISData/champ/photos",
        "c7d8c487-c377-42b0-a5b6-4c16db18fb41",
        // "--force-download",
        "--retain-project",
        // "--retain-download",
        // "--skip-upload",
      ],
      "request": "launch",
      "console": "integratedTerminal"
    }
  ]
}